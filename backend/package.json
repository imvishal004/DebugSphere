{
  "name": "debugsphere-backend",
  "version": "1.0.0",
  "description": "DebugSphere API & Worker",
  "main": "server.js",

  "engines": {
    "node": "18.x"
  },

  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "worker": "node worker.js",
    "worker:dev": "nodemon worker.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run worker:dev\""
  },

  "dependencies": {
    "axios": "^1.14.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.4",
    "fs-extra": "^11.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "uuid": "^9.0.0",
    "validator": "^13.11.0"
  },

  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}